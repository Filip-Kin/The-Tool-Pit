{
  "name": "@the-tool-pit/db",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/seed.ts",
    "db:seed-tools": "bun src/seed-tools.ts",
    "type-check": "tsc --noEmit",
    "build": "tsc"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "bun": "./src/schema/index.ts",
      "default": "./dist/schema/index.js"
    },
    "./client": {
      "bun": "./src/client.ts",
      "default": "./dist/client.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.0"
  }
}
