{
  "name": "the-tool-pit",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "turbo db:generate --filter=@the-tool-pit/db",
    "db:migrate": "turbo db:migrate --filter=@the-tool-pit/db",
    "db:push": "turbo db:push --filter=@the-tool-pit/db",
    "db:studio": "turbo db:studio --filter=@the-tool-pit/db",
    "test": "turbo test --filter=@the-tool-pit/web",
    "test:watch": "turbo test:watch --filter=@the-tool-pit/web"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "prettier": "^3.3.0"
  },
  "overrides": {
    "ioredis": "5.9.3"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11"
}
